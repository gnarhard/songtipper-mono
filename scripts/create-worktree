#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: ./scripts/create-worktree <track_id>

Run this from the main songtipper checkout.
Creates an ignored worktree at ./songtipper-worktrees/<track_id>
using the branch name codex/<track_id>.
Prints the absolute worktree path to stdout.
EOF
  exit 64
}

error() {
  printf 'ERROR: %s\n' "$1" >&2
  exit 1
}

[[ $# -eq 1 ]] || usage

track_id="$1"

if [[ ! "$track_id" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
  error "track_id must start with an alphanumeric character and use only letters, digits, dots, underscores, or hyphens"
fi

current_root="$(git rev-parse --show-toplevel 2>/dev/null)" || error "run this script from inside the songtipper repository"
current_root="$(cd "$current_root" && pwd -P)"

git_common_dir="$(git -C "$current_root" rev-parse --git-common-dir)" || error "could not resolve the repository common git directory"
git_common_dir="$(cd "$current_root" && cd "$git_common_dir" && pwd -P)"
main_repo_root="$(cd "$git_common_dir/.." && pwd -P)"

if [[ "$current_root" != "$main_repo_root" ]]; then
  error "run this script from the main songtipper checkout ($main_repo_root), not from an existing worktree"
fi

worktrees_root="$main_repo_root/songtipper-worktrees"
target_dir="$worktrees_root/$track_id"
branch_name="codex/$track_id"

if [[ -e "$worktrees_root" && ! -d "$worktrees_root" ]]; then
  error "worktrees root exists but is not a directory: $worktrees_root"
fi

if [[ -e "$target_dir" ]]; then
  error "target path already exists: $target_dir"
fi

if git -C "$main_repo_root" show-ref --verify --quiet "refs/heads/$branch_name"; then
  error "branch already exists: $branch_name"
fi

mkdir -p "$worktrees_root"

if ! output="$(git -C "$main_repo_root" worktree add "$target_dir" -b "$branch_name" 2>&1)"; then
  printf '%s\n' "$output" >&2
  error "git worktree add failed"
fi

printf '%s\n' "$output" >&2
printf 'Created worktree: %s\n' "$target_dir" >&2
printf 'Branch: %s\n' "$branch_name" >&2
printf '%s\n' "$target_dir"
