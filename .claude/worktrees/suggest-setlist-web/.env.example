APP_NAME="Song Tipper"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://songtipper.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=songtipper
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS="admin@example.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 Storage (for charts in production)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_DEFAULT_REGION=auto

# R2 Trash Bucket (soft-delete redundancy)
R2_TRASH_BUCKET=
R2_TRASH_RETENTION_DAYS=30
R2_TRASH_ENABLED=true

# Chart storage disk (use 'local' for development, 'r2' for production)
CHART_FILESYSTEM_DISK=local

# Chart render quality (DPI). Higher values are sharper but slower/larger.
CHART_RENDER_DPI=300
CHART_RENDER_QUEUE=renders
CHART_IDENTIFICATION_QUEUE=imports

VITE_APP_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_METHOD_DOMAIN=
STRIPE_MONTHLY_PRICE=
STRIPE_ANNUAL_PRICE=
STRIPE_LIFETIME_PRICE=

# AI provider for metadata enrichment, setlist generation, etc. (anthropic|openai|gemini)
AI_PROVIDER=anthropic

# Anthropic (Claude) configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_METADATA_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=45
ANTHROPIC_BATCH_THRESHOLD=50

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=45

# YouTube video auto-linking for Learn songs
YOUTUBE_DATA_API_KEY=
YOUTUBE_TIMEOUT_SECONDS=5

# Cloudflare R2 Storage (for charts in test)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_DEFAULT_REGION=